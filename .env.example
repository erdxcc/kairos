# Solana cluster: devnet for the MVP. Mainnet is a post-MVP milestone.
SOLANA_CLUSTER=devnet

# Any standard RPC endpoint works (public devnet, Helius free tier, etc.).
SOLANA_RPC_URL=https://api.devnet.solana.com

# Directory holding local keypairs generated by `pnpm setup:devnet`.
# Never commit this directory; it is gitignored.
KEYS_DIR=.keys

# Database.
#   - The worker and scripts default to embedded PGlite (no setup) when unset:
#       pglite://<repo>/.data/kairos-db
#   - The web app (Next.js) and any shared worker+web setup require Postgres.
#     Use a free Neon database or `docker compose up -d`, then `pnpm db:migrate`.
# DATABASE_URL=postgres://kairos:kairos@localhost:5432/kairos

# --- Indexer tuning (defaults shown) ---
# INDEXER_POLL_MS=8000          # delay between poll cycles
# INDEXER_BACKFILL_LIMIT=100    # signatures fetched on the very first run
# INDEXER_MAX_PAGES=3           # max signature pages per poll when catching up
# INDEXER_TX_DELAY_MS=400       # delay between getTransaction calls

# --- Billing engine (defaults shown) ---
# PULLER_KEYPAIR_PATH=.keys/puller.json  # devnet billing key; KMS in the mainnet milestone
# SCHEDULER_POLL_MS=30000       # how often due subscriptions are checked
# SCHEDULER_BATCH=10            # max charges attempted per cycle
# DISPATCHER_POLL_MS=10000      # webhook dispatch cycle
# WEBHOOK_MAX_ATTEMPTS=5        # delivery attempts before a delivery is dead
# RECONCILER_INTERVAL_MS=3600000 # on-chain account sweep interval

# --- Web dashboard / API ---
# AUTH_SECRET=change-me         # HMAC secret for SIWS nonce + session JWTs (REQUIRED when NODE_ENV=production)
# AUTH_DOMAIN=app.example.com   # domain shown in the Sign-In-With-Solana message (defaults to the request host)
# PULLER_PUBKEY=                # the worker's puller pubkey; shown in dashboard Settings so merchants can add it to their plan's pullers
