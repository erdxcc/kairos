# Solana cluster: devnet for the MVP. Mainnet is a post-MVP milestone.
SOLANA_CLUSTER=devnet

# Any standard RPC endpoint works (public devnet, Helius free tier, etc.).
SOLANA_RPC_URL=https://api.devnet.solana.com

# Directory holding local keypairs generated by `pnpm setup:devnet`.
# Never commit this directory; it is gitignored.
KEYS_DIR=.keys

